# AegisAI Frontend Environment
# Backend default from root .env.example:
# AEGIS_API_HOST=0.0.0.0
# AEGIS_API_PORT=8080

NEXT_PUBLIC_API_URL=http://localhost:8080

# Optional. If omitted, the frontend derives ws://localhost:8080/ws from NEXT_PUBLIC_API_URL.
# NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# Optional. Use only if the backend intentionally accepts a browser-visible dashboard key.
# Do not copy a private server AEGIS_API_KEY here for production deployments.
# NEXT_PUBLIC_AEGIS_API_KEY=
