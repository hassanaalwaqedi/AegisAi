# Copy this file to deploy/azure-vm.env on the VM and replace placeholder values.

# Azure Database for PostgreSQL Flexible Server
# Format:
# postgresql://<admin-user>:<password>@<server>.postgres.database.azure.com:5432/<database>?sslmode=require
DATABASE_URL=postgresql://aegis_admin:replace-me@your-server.postgres.database.azure.com:5432/postgres?sslmode=require

# API security
AEGIS_API_KEY=replace-with-a-long-random-secret
AEGIS_ALLOWED_ORIGINS=http://YOUR_VM_PUBLIC_IP:8080

# API server
AEGIS_API_HOST=0.0.0.0
AEGIS_API_PORT=8080
AEGIS_DEBUG=false

# Optional AI/NLQ integration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.7

# Optional semantic layer
SEMANTIC_ENABLED=false
SEMANTIC_BOX_THRESHOLD=0.35
SEMANTIC_TEXT_THRESHOLD=0.25
SEMANTIC_RISK_TRIGGER_THRESHOLD=0.6
SEMANTIC_CACHE_TTL=60
SEMANTIC_MAX_CONCURRENT=2
SEMANTIC_DEVICE=

